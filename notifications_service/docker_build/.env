# DATABASE
DB_USER=postgres
DB_PASS=postgres
DB_NAME=notifications_db
DB_PORT=5432
DB_URL=jdbc:postgresql://postgres:5432/notifications_db

# MESSAGE BROKER
MB_USER=rabbitmq
MB_PASS=rabbitmq
MB_VHOST=/
MB_HOST=message-broker
MB_PORT=5672

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_CON_TIMEOUT=5000
SMTP_TIMEOUT=10000
SMTP_WRITE_TIMEOUT=10000

# APPLICATION ENVs
## Notification cleaning
APP_NOTIFICATION_SCHEDULE_CLEANING_DELAY_MS=86400000
APP_NOTIFICATION_TTL_EMAIL_DAYS=7
APP_NOTIFICATION_TTL_VIEWED_DAYS=7
APP_NOTIFICATION_TTL_NOT_VIEWED_DAYS=30
APP_NOTIFICATION_NUMBER_RETRY_ATTEMPTS=2

## WebSocket
APP_WEBSOCKET_BASE_TOPIC=topic
APP_WEBSOCKET_ALLOWED_ORIGINS=localhost:8003

## CORS
APP_CORS_ALLOWED_ORIGINS=localhost:8003
APP_CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
APP_CORS_ALLOW_CREDENTIALS=false

## Messaging
APP_MESSAGING_INBOX_QUEUE=inbox-queue

## Inbox thread pool
APP_INBOX_THREAD_CORE_POOL_SIZE=50
APP_INBOX_THREAD_MAX_POOL_SIZE=80
APP_INBOX_THREAD_QUEUE_CAPACITY=120
APP_INBOX_THREAD_NAME_PREFIX=inbox-
APP_INBOX_THREAD_WAIT_TASKS_SHUTDOWN=true
APP_INBOX_THREAD_AWAIT_TERMINATION_SEC=60

## Inbox scheduling
APP_INBOX_RESERVATION_MIN=1
APP_INBOX_CLEANING_MIN=3
APP_INBOX_SCHEDULE_CLEANING_BATCH_SIZE=30
APP_INBOX_SCHEDULE_CLEANING_DELAY_MS=3000
APP_INBOX_SCHEDULE_PROCESSING_BATCH_SIZE=50
APP_INBOX_SCHEDULE_PROCESSING_DELAY_MS=10000