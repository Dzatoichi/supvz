# DATABASE
DB_USER=postgres
DB_PASS=postgres
DB_NAME=notifications_db
DB_PORT=5432
DB_URL=jdbc:postgresql://postgres:5432/notifications_db

# MESSAGE BROKER
MB_USER=rabbitmq
MB_PASS=rabbitmq
MB_VHOST=/
MB_HOST=message-broker
MB_PORT=5672

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_CON_TIMEOUT=5000
SMTP_TIMEOUT=10000
SMTP_WRITE_TIMEOUT=10000

# APPLICATION ENVs
MESSAGING_INBOX_QUEUE=notifications_queue
INBOX_RESERVATION_IN_MINUTES=5
SCHEDULING_POLLING_COUNT_BY_TIME=10