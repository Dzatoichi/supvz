# DATABASE
DB_USER=postgres
DB_PASS=postgres
DB_NAME=notifications_db
DB_PORT=5432
DB_URL=jdbc:postgresql://postgres:5432/notifications_db

# MESSAGE BROKER
MB_USER=rabbitmq
MB_PASS=rabbitmq
MB_VHOST=/
MB_HOST=message-broker
MB_PORT=5672

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_CON_TIMEOUT=5000
SMTP_TIMEOUT=10000
SMTP_WRITE_TIMEOUT=10000

# APPLICATION ENVs
MESSAGING_INBOX_QUEUE=inbox-queue
## inbox
INBOX_RESERVATION_IN_MINUTES=5
INBOX_CLEANING_IN_MINUTES=15
INBOX_CLEANING_BATCH_SIZE=10
INBOX_CLEANING_DELAY_IN_MS=10000
INBOX_PROCESSING_BATCH_SIZE=10
INBOX_PROCESSING_DELAY_IN_MS=2000
## websocket
WEBSOCKET_BASE_TOPIC=topic
## notifications
NOTIFICATION_PROCESSING_NUMBER_RETRIES=2
NOTIFICATION_THREAD_CORE_POOL_SIZE=20
NOTIFICATION_THREAD_MAX_POOL_SIZE=50
NOTIFICATION_THREAD_QUEUE_CAPACITY=50
NOTIFICATION_THREAD_NAME_PREFIX=notification
NOTIFICATION_THREAD_WAIT_TASKS_SHUTDOWN=true
NOTIFICATION_THREAD_AWAIT_TERMINATION_IN_SEC=60